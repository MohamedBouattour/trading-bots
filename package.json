{
  "name": "@trading-bots/source",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "docker": "docker compose up -d --build",
    "prisma:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=packages/database/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=packages/database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=packages/database/prisma/schema.prisma",
    "build": "npx nx run-many --target=build --all",
    "dev:db": "docker compose up -d postgres",
    "dev:back": "npx nx run-many --target=serve --projects=api-gateway,bot-worker,backtester,analytics,marketplace",
    "dev:front": "npx nx serve dashboard",
    "dev": "npm run dev:db && npx nx run-many --target=serve --all"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "22.7.1",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/nest": "22.7.1",
    "@nx/node": "22.7.1",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "~0.2.36",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-environment-node": "^29.7.0",
    "jest-preset-angular": "~16.0.0",
    "jest-util": "^29.7.0",
    "nx": "22.7.1",
    "prettier": "~3.6.2",
    "prisma": "^6.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tslib": "^2.3.0",
