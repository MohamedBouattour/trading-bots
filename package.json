    "optimize": "ts-node src/smart-grid/presentation/cli/optimize_cli.ts",
    "optimize-roi": "ts-node src/smart-grid/presentation/cli/optimize_max_roi_cli.ts",
    "open-order": "ts-node src/smart-grid/presentation/cli/open_order_cli.ts",
    "test": "vitest run"
  },
