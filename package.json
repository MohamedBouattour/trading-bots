{
  "name": "trading-bots",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently \"pnpm -F @trading-bots/engine dev\" \"pnpm -F @trading-bots/dashboard dev\"",
    "test": "vitest run",
    "lint": "eslint packages --ext .ts,.tsx"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^9.0.0"
  }
}
