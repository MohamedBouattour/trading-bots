{
  "id": "ema-cross-v1",
  "name": "EMA 9/21 Crossover",
  "version": "1.0.0",
  "description": "Classic EMA crossover: buy when fast EMA crosses above slow EMA, sell on reverse cross.",
  "symbols": ["BTCUSDT"],
  "defaultTimeframe": "15m",
  "indicators": [
    { "id": "ema9",  "type": "EMA", "params": { "period": 9  }, "timeframe": "15m" },
    { "id": "ema21", "type": "EMA", "params": { "period": 21 }, "timeframe": "15m" },
    { "id": "rsi14", "type": "RSI", "params": { "period": 14 }, "timeframe": "15m" }
  ],
  "rules": [
    {
      "id": "ema-bull-cross",
      "name": "Fast EMA above slow EMA + RSI not overbought",
      "priority": 1,
      "conditionGroup": {
        "logic": "AND",
        "conditions": [
          { "left": "ema9",  "operator": ">",  "right": "ema21" },
          { "left": "rsi14", "operator": "<",  "right": 70 }
        ]
      },
      "action": "BUY",
      "params": { "sizeMode": "pct_balance", "sizeValue": 8, "leverage": 3, "slPct": 2, "tpPct": 6 }
    },
    {
      "id": "ema-bear-cross",
      "name": "Fast EMA below slow EMA",
      "priority": 2,
      "conditionGroup": {
        "logic": "AND",
        "conditions": [
          { "left": "ema9", "operator": "<", "right": "ema21" }
        ]
      },
      "action": "SELL",
      "params": { "sizeMode": "pct_balance", "sizeValue": 100 }
    },
    {
      "id": "hold",
      "name": "No signal",
      "priority": 99,
      "conditionGroup": { "logic": "AND", "conditions": [] },
      "action": "HOLD"
    }
  ],
  "loop": { "intervalSeconds": 900 },
  "riskManagement": {
    "maxDrawdownPct": 15,
    "maxPositionPct": 10,
    "dailyLossLimitPct": 3
  },
  "metadata": {
    "author": "MohamedBouattour",
    "createdAt": "2025-01-01",
    "tags": ["crossover", "ema", "scalp"]
  }
}
