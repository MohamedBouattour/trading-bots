{
  "id": "rsi-trend-v1",
  "name": "RSI + SMA Trend Strategy",
  "symbols": ["BTCUSDT", "ETHUSDT"],
  "indicators": [
    { "id": "rsi14",  "type": "RSI",  "params": { "period": 14 }, "timeframe": "1h" },
    { "id": "sma200", "type": "SMA",  "params": { "period": 200 }, "timeframe": "1h" },
    { "id": "atr14",  "type": "ATR",  "params": { "period": 14 }, "timeframe": "1h" }
  ],
  "rules": [
    {
      "id": "buy-signal",
      "name": "RSI momentum + price above SMA200",
      "priority": 1,
      "conditionGroup": {
        "logic": "AND",
        "conditions": [
          { "left": "rsi14",       "operator": ">",  "right": 50 },
          { "left": "rsi14",       "operator": "<",  "right": 70 },
          { "left": "price.close", "operator": ">",  "right": "sma200" }
        ]
      },
      "action": "BUY",
      "params": { "sizeMode": "pct_balance", "sizeValue": 10, "leverage": 2 }
    },
    {
      "id": "sell-signal",
      "name": "RSI overbought exit",
      "priority": 2,
      "conditionGroup": {
        "logic": "OR",
        "conditions": [
          { "left": "rsi14", "operator": ">=", "right": 70 },
          { "left": "price.close", "operator": "<", "right": "sma200" }
        ]
      },
      "action": "SELL",
      "params": { "sizeMode": "pct_position", "sizeValue": 100 }
    }
  ],
  "loop": { "intervalSeconds": 3600 },
  "riskManagement": {
    "maxDrawdownPct": 20,
    "maxPositionPct": 15,
    "dailyLossLimitPct": 5,
    "stopLossMode": "atr",
    "stopLossAtrMultiplier": 2
  }
}
